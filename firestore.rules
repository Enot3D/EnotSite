rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }

    // Projects (Orders) - all authenticated can read/write
    match /projects/{projectId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Products - anyone can read, authenticated can write (admin check in app)
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Reviews - anyone can read, authenticated can create/delete own
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Promo codes - anyone can read, authenticated can write
    match /promos/{promoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Settings - anyone can read, authenticated can write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
